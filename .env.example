# Database
DATABASE_URL=postgresql://dotzero:dotzero@localhost:5432/dotzero_crms

# Auth
JWT_SECRET=replace_with_random_64_char_string
NEXTAUTH_SECRET=replace_with_random_64_char_string
NEXTAUTH_URL=http://localhost:3000

# Email
SENDGRID_API_KEY=replace_with_sendgrid_api_key
EMAIL_FROM=noreply@dotzero.com

# File Storage
S3_BUCKET=dotzero-cr-attachments
S3_REGION=us-east-1
S3_ACCESS_KEY=replace_with_s3_access_key
S3_SECRET_KEY=replace_with_s3_secret_key

# App
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000

# Monitoring (optional in dev)
SENTRY_DSN=
